# Grey local environment example.
# Copy to .env for local development. Do not commit real secrets.

APP_NAME="Grey Backend API"
VERSION="1.0.0"
DEBUG=false

HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["*"]

MONGO_URI=mongodb://localhost:27020/vinh
MONGO_DB=vinh

WORKSPACE_ROOT=.
DATA_DIR=./data
QUANTA_ALPHA_ROOT=./backend/engines/quanta
SOVA_ROOT=./backend/engines/sova

GREY_MAX_WORKERS=4
GREY_FAST_MODE=true
GREY_VECTORIZED=true

# Optional external integrations. Keep real values only in local .env or a secret manager.
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
